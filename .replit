PORT = "5000"
DATABASE_URL = "postgresql://neondb_owner:npg_jv9L6xN9Jcwi@ep-orange-dawn-a5x16rwj.us-east-2.aws.neon.tech/neondb?sslmode=require"
ADMIN_EMAILS = "nadia@metahers.ai,hello@metahers.ai,metahers@gmail.com"

[workflows]
runButton = "Project"

[[workflows.workflow]]
